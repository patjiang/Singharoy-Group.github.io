  <script>
    const topicLinks = Array.from(document.querySelectorAll("[data-topic-link]"));
    const topicResults = Array.from(document.querySelectorAll("[data-topic-result]"));
    const projectCards = Array.from(document.querySelectorAll("[data-project-topics]"));

    const showTopic = (topicSlug) => {
      topicLinks.forEach(l => l.classList.toggle("active", (l as HTMLElement).dataset.topicLink === topicSlug));
      topicResults.forEach(r => r.classList.toggle("active", (r as HTMLElement).dataset.topicResult === topicSlug));
      projectCards.forEach(c => {
        const topics = (c as HTMLElement).dataset.projectTopics?.split(" ") || [];
        c.classList.toggle("isHidden", !!topicSlug && !topics.includes(topicSlug));
      });
    };

    topicLinks.forEach(link => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const slug = (link as HTMLElement).dataset.topicLink || "";
        showTopic(slug);
        window.history.pushState({}, "", `?topic=${slug}#topic-map`);
      });
    });

    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has("topic")) showTopic(urlParams.get("topic") || "");
  </script>
